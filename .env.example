# Copy this file to .env for local development.
# Never commit .env with real credentials.

# Official/runtime IO defaults.
INPUT_PATH=/input/tasks.json
OUTPUT_PATH=/output/results.json

# Fireworks remote inference. Leave placeholders until you have real values.
FIREWORKS_API_KEY=replace-with-your-key
FIREWORKS_BASE_URL=replace-with-evaluator-or-fireworks-compatible-base-url
ALLOWED_MODELS=minimax-m3,kimi-k2p7-code,gemma-4-31b-it,gemma-4-26b-a4b-it,gemma-4-31b-it-nvfp4

# Optional telemetry.
# ROUTER_LOG_PATH=/output/router_log.jsonl

# Optional local-model runtime.
LOCAL_MODEL_ENABLED=false
LOCAL_MODEL_PATH=/app/models/local-model.gguf
LOCAL_MODEL_CATEGORIES=sentiment_classification,text_summarisation
